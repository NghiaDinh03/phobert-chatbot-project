# ================================================================
# CyberAI Assessment Platform — environment variables
# ================================================================
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# Required: CLOUD_API_KEYS (free dev key works — see Quick Start in README.md)
# Generate JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
# ================================================================

# ====== MODEL & LLM ======
LOCALAI_URL=http://localai:8080
OLLAMA_URL=http://ollama:11434

# Phase 2 (Report formatting) — Meta-Llama 8B Q4 ~5GB RAM
MODEL_NAME=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
# Phase 1 (GAP analysis) — SecurityLLM 7B Q4 ~4GB RAM
SECURITY_MODEL_NAME=SecurityLLM-7B-Q4_K_M.gguf

MAX_TOKENS=-1
DEBUG=true
THREADS=6
CONTEXT_SIZE=8192

# false = Cloud-first (default — works without local models)
# true  = Local-first (only after LocalAI/Ollama models are pulled)
PREFER_LOCAL=false

# ====== CLOUD LLM API (Open Claude — free dev tier) ======
CLOUD_LLM_API_URL=https://open-claude.com/v1
CLOUD_MODEL_NAME=gemini-3.1-pro-preview
# Get a free key at https://open-claude.com — required for cloud fallback
CLOUD_API_KEYS=your-cloud-api-key-here

# Google AI Studio (Gemini free tier) — used as last-resort cloud fallback
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key-here
GOOGLE_AI_STUDIO_MODEL=gemini-2.0-flash
GOOGLE_AI_STUDIO_URL=https://generativelanguage.googleapis.com/v1beta

# ====== DATA PATHS (inside container) ======
ISO_DOCS_PATH=/data/iso_documents
VECTOR_STORE_PATH=/data/vector_store
DATA_PATH=/data
HF_HOME=/data/models/huggingface

# ====== BACKEND ======
LOG_LEVEL=INFO

# ====== SECURITY ======
CORS_ORIGINS=http://localhost:3000
# JWT_SECRET MUST be ≥32 chars in production. App refuses to start with weak values.
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

# ====== RATE LIMITING ======
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_ASSESS=3/minute
RATE_LIMIT_BENCHMARK=5/minute

# ====== PERFORMANCE ======
# 1200s = 20 min — needed for Gemma 4 (slow on CPU). Reduce to 300 for cloud-only.
INFERENCE_TIMEOUT=1200
CLOUD_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=3

# ====== ASSESSMENT PIPELINE (Step 3 hybrid) ======
# ASSESSMENT_MODE — default mode used by /iso27001/assess when the request
# does not override it. One of: hybrid | local | cloud.
#   hybrid: SecurityLM evidence summary → local mid-size chunk drafting → cloud final report
#   local : no cloud calls; SecurityLM summary + local chunk drafting + local report
#   cloud : legacy behavior — all phases on cloud
ASSESSMENT_MODE=hybrid
# Token cap for the SecurityLM evidence-summary step in hybrid/local mode.
EVIDENCE_SUMMARY_TOKENS=256
# Step 8 docker RAM guard threshold (GB) — when host RAM < this, the local
# pipeline declines to start large models. Read by docker-compose checks.
LOCAL_RAM_GUARD_GB=20.0

# ====== HUGGINGFACE (optional — for gated models like Gemma) ======
# Token type: Read. https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
