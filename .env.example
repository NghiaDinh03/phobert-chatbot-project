# -------------------------------------------------------------
# Cấu hình Môi trường (Environment Variables) - PhoBERT AI Platform
# -------------------------------------------------------------

# ======= MODEL & LLM SETTINGS =======
# Đường dẫn kết nối server inference nội bộ (LocalAI)
LOCALAI_URL=http://localai:8080

# Tên file GGUF model chính (Dùng cho Chatbot, Sinh Report, Tóm tắt báo)
MODEL_NAME=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf

# Tên file GGUF model bảo mật chuyên đo lường Form ISO
SECURITY_MODEL_NAME=SecurityLLM-7B-v0.1-Q4_K_M.gguf

# Số lượng Token tối đa trả về (-1 là không giới hạn)
MAX_TOKENS=-1

# Tùy chỉnh LLM Execution
DEBUG=true
THREADS=4
CONTEXT_SIZE=8192
GPU_LAYERS=16

# ======= ĐƯỜNG DẪN DỮ LIỆU =======
# Thư mục chứa tài liệu RAG tiêu chuẩn
ISO_DOCS_PATH=/data/iso_documents

# Nơi chứa thông tin Cache Vector (ChromaDB)
VECTOR_STORE_PATH=/data/vector_store

# Thư mục lưu dữ liệu cục bộ tổng hợp (News JSON, Âm thanh TTS)
DATA_PATH=/data

# Thư mục lưu cấu hình ôm trọn cache HuggingFace của model VinAI
HF_HOME=/data/models/huggingface

# ======= BACKEND & LOGGING =======
# Server backend API (Cổng gọi nội bộ)
BACKEND_URL=http://backend:8000

# Tuỳ chọn ghi log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Tùy chọn: API Key của Gemini nếu có luồng Fallback dự phòng
GEMINI_API_KEY=your_gemini_api_key_here
