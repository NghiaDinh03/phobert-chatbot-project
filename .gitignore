# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/

# Runtime data — không commit lên GitHub (sinh ra khi chạy ứng dụng)
data/sessions/*
!data/sessions/.gitkeep
data/uploads/*
!data/uploads/.gitkeep
data/summaries/*
!data/summaries/.gitkeep
data/summaries/audio/*
data/assessments/*
!data/assessments/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/evidence/*
!data/evidence/.gitkeep
data/articles_history.json
data/translations/*.json
data/standards/*
!data/standards/.gitkeep

# Vector store runtime files (rebuilt on startup via reindex)
data/vector_store/*.faiss
data/vector_store/chroma.sqlite3
data/vector_store/*/

# Models (large files)
models/
*.gguf
*.bin
*.safetensors

# Dev/AI assistant context files (không liên quan đến source code đề tài)
context.md
.claude/
.cursor/
.roo/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment (chứa API keys — KHÔNG commit)
.env

# Docker
.dockerignore

# Node.js / Next.js
node_modules/
.next/
frontend-next/.next/
frontend-next/node_modules/
frontend-next/.env.local

# Sensitive files
*.key
*.pem
*.cert
*.secret
*.p12

# Misc
hash.txt
.vs/
