# ================================================================
# CyberAI Assessment Platform — .gitignore
# ================================================================
# Push everything except: secrets, runtime artifacts, build outputs, large models, logs.
# ================================================================

# ====== Secrets — NEVER commit ======
.env
.env.*
!.env.example
frontend-next/.env
frontend-next/.env.local
frontend-next/.env.*.local
backend/.env
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
*.secret
secrets/
credentials.json
service-account*.json
*-credentials.json
gcp-key*.json

# ====== Logs ======
*.log
logs/
backend.log
ollama.log
_bk.log
_fe.log
backend/*.log
frontend-next/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====== Python ======
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt

# ====== Node.js / Next.js build output ======
node_modules/
.next/
frontend-next/.next/
frontend-next/node_modules/
frontend-next/out/
frontend-next/build/
frontend-next/.turbo/
out/
.turbo/
.npm/
.yarn/
.pnp.*
*.tsbuildinfo
next-env.d.ts

# ====== Large model weights — too big for git ======
models/
*.gguf
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.ckpt
*.h5
*.tflite

# ====== Runtime user data — generated per machine ======
data/sessions/*
!data/sessions/.gitkeep
data/uploads/*
!data/uploads/.gitkeep
data/summaries/*
!data/summaries/.gitkeep
data/summaries/audio/*
data/assessments/*
!data/assessments/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/evidence/*
!data/evidence/.gitkeep
data/articles_history.json
data/translations/*.json
data/standards/*
!data/standards/.gitkeep

# ====== Vector store runtime — rebuilt on startup ======
data/vector_store/*.faiss
data/vector_store/chroma.sqlite3
data/vector_store/*/

# ====== Backups / dumps / archives ======
*.bak
*.backup
*.old
*.orig
*.tmp
*.swp
*.swo
*.dump
*.sql.gz
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar
backup/
backups/

# ====== IDE / OS ======
.vscode/
!.vscode/settings.shared.json
.idea/
.vs/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ====== Misc / scratch ======
hash.txt
/context.md
TODO.local.md
NOTES.local.md
scratch/
tmp/
temp/
.cache/

# ====== Local tool caches ======
.claude/

# ====== Runtime data (writable per-machine) ======
backend/data/
